# Local build configuration for build-ios.sh
# Edit this file directly, it won't be committed to version control

# This keeps the build unsigned by default (for sideloading).
IOS_CODESIGN="0"

# Want a signed build for your own registered devices? Use these instead.
# IOS_CODESIGN="1"
# IOS_EXPORT_METHOD="development"

# Or use a custom export options plist file (instead of --export-method).
# Can be an absolute path or relative to the repo root.
# IOS_EXPORT_OPTIONS_PLIST="ios/ExportOptions-development.plist"

# If Flutter isn't on your PATH, point to it here.
# FLUTTER_BIN="$HOME/flutter/bin/flutter"